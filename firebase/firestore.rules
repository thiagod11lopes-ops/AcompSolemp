rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Código da organização — leitura pública para login da timeline
    match /orgCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.tenantId == request.auth.uid;
    }

    // Banco isolado por conta Google (tenantId = uid do gestor)
    match /tenants/{tenantId}/appState/{docId} {
      allow read, write: if request.auth != null;
    }

    // Legado — manter temporariamente
    match /appState/{docId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
