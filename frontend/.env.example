# Fonte de dados: local (IndexedDB) ou firebase (Firestore)
VITE_DATA_SOURCE=local

# Firebase — crie um projeto em https://console.firebase.google.com
# e copie as credenciais do app Web
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Documento transitório com snapshot AppData (fase 1 da migração)
VITE_FIREBASE_APP_STATE_DOC=appState/current
